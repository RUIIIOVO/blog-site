# ===== WebDAV 同步 =====
WEBDAV_BASE_URL=https://example.com/webdav
WEBDAV_USERNAME=your_webdav_username
WEBDAV_PASSWORD=your_webdav_password
WEBDAV_POSTS_PATH=/posts
WEBDAV_ASSETS_PATH=/assets

# ===== 构建/站点 =====
SITE_URL=https://your-domain.com
TZ=Asia/Shanghai

# ===== 部署（本地手动部署或脚本场景可用） =====
DEPLOY_HOST=your-server-ip
DEPLOY_PORT=22
DEPLOY_USER=ubuntu
DEPLOY_TARGET_BASE=/home/ubuntu/blog-site

# ===== Giscus（可选） =====
GISCUS_ENABLED=false
GISCUS_REPO=
GISCUS_REPO_ID=
GISCUS_CATEGORY=Announcements
GISCUS_CATEGORY_ID=
GISCUS_MAPPING=pathname
GISCUS_STRICT=0
GISCUS_REACTIONS_ENABLED=1
GISCUS_EMIT_METADATA=0
GISCUS_INPUT_POSITION=top
GISCUS_LANG=zh-CN
GISCUS_LOADING=lazy

# ===== Analytics（可选） =====
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=umami
ANALYTICS_SCRIPT_URL=
ANALYTICS_WEBSITE_ID=
ANALYTICS_DOMAIN=

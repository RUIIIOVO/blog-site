&amp;#34;fresco-okhttp3&amp;#34;: &amp;#34;com.facebook.fresco:imagepipeline-okhttp3:&amp;#34; + frescoVersion,
&amp;#34;fresco-webpsupport&amp;#34; : &amp;#34;com.facebook.fresco:webpsupport:&amp;#34; + frescoVersion,
